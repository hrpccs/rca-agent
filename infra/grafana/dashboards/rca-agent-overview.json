      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "OpenTelemetry Collector self-metrics: rate of OTLP records received. Healthy pipeline shows non-zero throughput; a flat zero means the app is not exporting. Source: collector :8888.",
      "fieldConfig": {
