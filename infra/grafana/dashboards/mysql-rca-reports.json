{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "RCA reports and runs persisted in MySQL by the rca-server: reports per case, average root-cause confidence, recent runs. Datasource: MySQL (uid 'mysql').",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "description": "Number of RCA reports stored per case. Table read directly from the rca-server's MySQL persistence layer.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "reports" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "mode": "gradient", "type": "gauge" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "enablePagination": true, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT case_id, COUNT(*) AS reports FROM reports WHERE finished_at >= FROM_UNIXTIME(${__from:date_seconds}) GROUP BY case_id ORDER BY reports DESC;",
          "refId": "A"
        }
      ],
      "title": "Reports per case",
      "type": "table"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "description": "Average root-cause confidence per case over the selected window. Confidence is 0..1 as emitted by the agent in the final RcaReport.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.4 }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.8 } ] },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT case_id, AVG(confidence) AS avg_confidence FROM reports WHERE finished_at >= FROM_UNIXTIME(${__from:date_seconds}) GROUP BY case_id ORDER BY avg_confidence DESC;",
          "refId": "A"
        }
      ],
      "title": "Avg confidence per case",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "description": "Most recent RCA runs: case, status, confidence, model, and timing. Status is completed | error | truncated.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "completed": { "color": "green", "index": 0 }, "error": { "color": "red", "index": 1 }, "truncated": { "color": "orange", "index": 2 } }, "type": "value" }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "confidence" },
            "properties": [ { "id": "unit", "value": "percentunit" }, { "id": "decimals", "value": 2 } ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "enablePagination": true, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT id, case_id, status, confidence, model, started_at, finished_at FROM reports ORDER BY started_at DESC LIMIT 100;",
          "refId": "A"
        }
      ],
      "title": "Recent runs",
      "type": "table"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "description": "Run outcomes over time: completed vs error vs truncated.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 19 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT status AS metric, UNIX_TIMESTAMP(DATE(started_at)) AS time_sec, COUNT(*) AS value FROM reports WHERE started_at >= FROM_UNIXTIME(${__from:date_seconds}) GROUP BY status, DATE(started_at) ORDER BY time_sec;",
          "refId": "A"
        }
      ],
      "title": "Runs by status over time",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["rca-agent", "mysql"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "MySQL", "value": "mysql" },
