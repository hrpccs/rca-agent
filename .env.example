# Copy to .env and fill in. .env is gitignored.
# LLM (DeepSeek thinking mode). Get a key at https://platform.deepseek.com
RCA_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RCA_DEEPSEEK_BASE_URL=https://api.deepseek.com
RCA_DEEPSEEK_MODEL=deepseek-reasoner
RCA_REASONING_EFFORT=high

# Agent loop limits
RCA_LLM_MAX_STEPS=25
RCA_LLM_MAX_TOKENS=8192

# Data backend: "parquet" (reads the benchmark files directly) or "clickhouse"
RCA_DATA_BACKEND=parquet
RCA_CASES_DIR=/Users/hrpccs/Desktop/workspace/aiops/rca100/cases

# ClickHouse (used when RCA_DATA_BACKEND=clickhouse, and for observability)
RCA_CLICKHOUSE_HOST=localhost
RCA_CLICKHOUSE_PORT=8123
RCA_CLICKHOUSE_USER=rca
RCA_CLICKHOUSE_PASSWORD=rca123
RCA_CLICKHOUSE_DATABASE=rca

# MySQL (rca-server persistence)
RCA_MYSQL_URL=mysql+pymysql://rca:rca123@localhost:3306/rca

# Server
RCA_SERVER_HOST=0.0.0.0
RCA_SERVER_PORT=8000

# Memory
RCA_MEMORY_BACKEND=inmemory

# OpenTelemetry (OTLP gRPC endpoint = otel-collector)
RCA_OTEL_ENDPOINT=http://localhost:4317
RCA_OTEL_SERVICE_NAME=rca-agent
